ASYNC_POST_LIKE=true
DEBUG=false

# HTTP Server
X_CLONE_HTTP_SERVER_PORT=3000
X_CLONE_POST_PPROF_HTTP_PREFIX="/tmp-pprof"

# PostgreSQL Database
X_CLONE_POSTGRES_HOST=host.docker.internal
X_CLONE_POSTGRES_PORT=5432
X_CLONE_POSTGRES_SSL_MODE=disable
X_CLONE_POSTGRES_USER=postgres
X_CLONE_POSTGRES_PASSWORD=
X_CLONE_POSTGRES_DB_NAME=x_clone_post
